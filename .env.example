# Firebase web app config — get these from:
# Firebase Console > Project Settings > General > Your apps > SDK setup and configuration
#
# Copy this file to .env, fill in the values, then restart the Expo dev server
# (env vars are read at bundle time, not hot-reloaded).
#
# EXPO_PUBLIC_ prefix is required for Expo to inline these into the client
# bundle — see https://docs.expo.dev/guides/environment-variables/
# These values identify your Firebase project; they are not secret keys.
# Access to your data is controlled by Firebase Security Rules, not by
# keeping these values hidden.

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
